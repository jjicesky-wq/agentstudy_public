# ============================================
# Agent Study - Environment Variables
# ============================================
# Copy this file to '.env' and fill in your values
# The .env file is automatically loaded by the application
# DO NOT commit .env to version control - it contains secrets!

# ============================================
# OPTIONAL - OpenAI API
# ============================================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: Specify which model to use (default: gpt-4)
# OPENAI_MODEL=gpt-4

# ============================================
# OPTIONAL - Azure OpenAI (Alternative to OpenAI)
# ============================================
# Use Azure OpenAI instead of standard OpenAI API
# Get credentials from Azure Portal: https://portal.azure.com
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=your-deployment-name
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ============================================
# OPTIONAL - Database (PostgreSQL)
# ============================================
# If not set, SQLite will be used automatically
# PostgreSQL connection details
PG_HOST=
PG_PORT=
PG_USERNAME=
PG_PASSWORD=
PG_DBNAME=

# PostgreSQL superuser credentials (for database creation)
PG_SU_USERNAME=
PG_SU_PASSWORD=

# ============================================
# OPTIONAL - SQLite (Development)
# ============================================
# Directory for SQLite database file (defaults to src/data/)
# SQLITE_FILE_DIRECTORY=src/data

# ============================================
# OPTIONAL - Anthropic/Claude API
# ============================================
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022


# ============================================
# OPTIONAL - Development/Testing Flags
# ============================================
# Use mock services to avoid API costs during development
# USE_MOCK_MODEL=false  # Mock all AI models (OpenAI, Claude, etc.)


# ============================================
# OPTIONAL - Debug Logging
# ============================================
# Enable console logging (set to any value to enable)
DEBUG_LOG_TO_CONSOLE=1

# Enable file logging (set to file path to enable)
# DEBUG_LOG_TO_FILE=logs/debug.log

# Enable database logging (set to any value to enable)
# DEBUG_LOG_TO_DB=1
